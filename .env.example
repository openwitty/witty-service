# Witty Service Configuration
# Copy this file to .env and customize the values

# ==============================================================================
# 基础配置 / Base Configuration
# ==============================================================================

# 认证令牌 (默认: dev-token)
AUTH_TOKEN=dev-token

# ==============================================================================
# 工作空间配置 / Workspace Configuration
# ==============================================================================

# 工作空间根目录 (默认: ~/.witty)
WITTY_WORKSPACE_ROOT=~/.witty

# Agent服务器应用目录 (可选)
# WITTY_AGENT_SERVER_APP_DIR=

# ==============================================================================
# 数据库配置 / Database Configuration
# ==============================================================================

# 数据库连接URL (默认: sqlite:///~/.witty/db/witty_service.sqlite3)
WITTY_DATABASE_URL=sqlite:///~/.witty/db/witty_service.sqlite3

# ==============================================================================
# 日志配置 / Logging Configuration
# ==============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR (默认: INFO)
WITTY_LOG_LEVEL=INFO

# 日志文件路径 (默认: $WITTY_WORKSPACE_ROOT/logs/witty-service.log)
WITTY_LOG_FILE=~/.witty/logs/witty-service.log

# 单个日志文件最大字节数 (默认: 10485760 = 10MB)
WITTY_LOG_MAX_BYTES=10485760

# 备份日志文件数量 (默认: 5)
WITTY_LOG_BACKUP_COUNT=5

# ==============================================================================
# Docker沙箱配置 / Docker Sandbox Configuration
# ==============================================================================

# Docker主机地址 (默认: 127.0.0.1)
WITTY_DOCKER_HOST=127.0.0.1

# Docker容器端口 (默认: 8080)
WITTY_DOCKER_CONTAINER_PORT=8080

# Docker容器内工作空间路径 (默认: /witty-workspace)
WITTY_DOCKER_CONTAINER_WORKSPACE_PATH=/witty-workspace

# Docker容器停止超时时间(秒) (默认: 10)
WITTY_DOCKER_STOP_TIMEOUT=10

# Docker镜像名称 (默认: witty-agent-server)
WITTY_DOCKER_IMAGE=witty-agent-server

# Docker镜像标签 (默认: latest)
WITTY_DOCKER_IMAGE_TAG=latest

# ==============================================================================
# OpenClaw Gateway配置 / OpenClaw Gateway Configuration
# ==============================================================================

# 网关空闲超时时间(秒) (默认: 1200)
OPENCLAW_GATEWAY_IDLE_TIMEOUT=1200

# 生命周期结束排水超时时间(秒) (默认: 60)
OPENCLAW_GATEWAY_LIFECYCLE_END_DRAIN_TIMEOUT=60

# 状态目录 (可选)
# OPENCLAW_STATE_DIR=

# ==============================================================================
# OpenClaw配置 / OpenClaw Configuration
# ==============================================================================

# OpenClaw配置文件路径 (默认: ~/.openclaw/openclaw.json)
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
