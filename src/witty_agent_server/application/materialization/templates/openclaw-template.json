{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "token": "${ACCESS_TOKEN}"
    },
    "remote": {
      "token": "${ACCESS_TOKEN}"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "deepseek": {
        "baseUrl": "${BASE_URL}",
        "apiKey": "${API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "${MODEL_NAME}",
            "name": "${MODEL_NAME}",
            "reasoning": true,
            "contextWindow": 1050000,
            "maxTokens": 128000,
            "input": [
              "text"
            ]
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "deepseek/deepseek-chat"
      },
      "models": {
        "deepseek/deepseek-chat": {
          "alias": "deepseek-chat"
        }
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "session": {
    "resetByType": {
      "dm": {
        "mode": "daily",
        "atHour": 4
      },
      "group": {
        "mode": "daily",
        "atHour": 4
      }
    }
  }
}